{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "admin_backup",
    "components/admin-question-editor.tsx",
    "components/admin-question-form.tsx",
    "components/admin-toolbar.tsx",
    "components/ai-question-generator.tsx",
    "components/analytics-cards.tsx",
    "components/bulk-upload-form.tsx",
    "components/favorites-list.tsx",
    "components/auth-panel.tsx"
  ]
}